// Prisma schema - SQLite local (usuário e ajustes). Pedidos vêm do SQL que você colar (Nomus read-only).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DB_URL")
}

// Tabela auxiliar para ajustes manuais de previsão de entrega (histórico)
model PedidoPrevisaoAjuste {
  id            Int      @id @default(autoincrement())
  id_pedido     String   // ID do pedido no ERP (varchar para compatibilidade)
  previsao_nova DateTime
  motivo        String
  observacao    String?
  usuario       String
  data_ajuste   DateTime @default(now())

  @@index([id_pedido])
  @@index([data_ajuste])
  @@map("pedido_previsao_ajuste")
}

model MotivoSugestao {
  id        Int      @id @default(autoincrement())
  descricao String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Motivos da alteração da data de entrega do pedido de compra (Integração Nomus) – cadastro separado da aba Pedidos
model MotivoAlteracaoDataEntregaCompra {
  id        Int      @id @default(autoincrement())
  descricao String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("motivo_alteracao_data_entrega_compra")
}

// Grupo de usuários: define permissões de acesso
model GrupoUsuario {
  id          Int      @id @default(autoincrement())
  nome        String   @unique
  descricao   String?
  permissoes  String   // JSON array: ["dashboard.ver", "pedidos.ver", ...]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usuarios Usuario[]

  @@map("grupo_usuario")
}

// Usuário para autenticação (login/senha) - tabela local do app
model Usuario {
  id        Int          @id @default(autoincrement())
  login     String       @unique
  senhaHash String
  nome      String?
  grupoId   Int?
  fotoUrl   String? // Foto do usuário (data URL base64 ou URL). Opcional.
  createdAt DateTime     @default(now())

  grupo GrupoUsuario? @relation(fields: [grupoId], references: [id], onDelete: SetNull)
  sycroOrdersCriados    SycroOrderOrder[]
  sycroOrderHistory     SycroOrderHistory[]
  sycroOrderNotifications SycroOrderNotification[]
  sycroOrderOrderReads    SycroOrderOrderRead[]

  @@map("usuario")
}

// Configuração persistida (ex.: Evolution WhatsApp – instância e número para envio)
model Config {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("config")
}

// Coordenadas de municípios brasileiros (fonte: IBGE/kelvins – sem depender de API externa)
model MunicipioCoordenada {
  id               Int    @id @default(autoincrement())
  nome_normalizado String // nome sem acentos, minúsculo, para comparação
  uf               String // sigla: MA, PI, etc.
  lat              Float
  lng              Float

  @@unique([nome_normalizado, uf])
  @@index([nome_normalizado, uf])
  @@map("municipio_coordenada")
}

// Coleta de preços: uma confirmação de seleção no modal (idProduto do Nomus)
// Histórico de alteração de data de entrega do item de pedido de compra (Nomus). Gravado no banco do projeto.
model PedidoCompraDataEntregaAlteracao {
  id                   Int      @id @default(autoincrement())
  idItemPedidoCompra   Int      // id do item no Nomus (itempedidocompra.id)
  dataEntregaAnterior  String   // data antes da alteração (YYYY-MM-DD)
  dataEntregaNova      String   // data após alteração (YYYY-MM-DD)
  motivo               String
  observacao           String?
  usuario              String   // login de quem alterou
  dataAlteracao        DateTime @default(now())

  @@index([idItemPedidoCompra])
  @@index([dataAlteracao])
  @@map("pedido_compra_data_entrega_alteracao")
}

model ColetaPrecos {
  id                  Int       @id @default(autoincrement())
  createdAt           DateTime  @default(now())
  usuarioCriacao      String?   // login do usuário que criou a coleta
  fornecedores        String?   // JSON array de até 6 nomes de fornecedores da cotação
  status                      String?   @default("Em cotação") // "Em cotação" | "Em Aprovação" | "Rejeitada" | "Finalizada" | "Enviado para Financeiro"
  dataEnvioAprovacao          DateTime?  // quando foi enviado para aprovação (zerado ao reabrir)
  jaEnviadaAprovacao          Boolean   @default(false) // true assim que foi enviada para aprovação uma vez; nunca volta a false (bloqueia exclusão)
  justificativaCancelamento  String?   // justificativa ao cancelar (reverter) aprovação
  dataCancelamento           DateTime?  // quando foi cancelada a aprovação
  dataFinalizacao            DateTime?  // quando foi finalizada ou enviada ao financeiro (para cálculo de tempo em cotação)
  observacoes                 String?   // observações da coleta (texto longo); exibido no mapa de cotação
  dataUltimaMovimentacao     DateTime?  // última alteração (status, cotação, itens etc.); usado na regra de 72h para bloquear nova coleta

  itens       ColetaPrecosItem[]
  registros   ColetaPrecosRegistro[]
  cotacoes    ColetaPrecosCotacao[]
  ciencias    ColetaPrecosCiencia[]

  @@map("coleta_precos")
}

// Ciência dada pelo usuário para coleta com mais de 72h em aberto (desbloqueia criar nova coleta)
model ColetaPrecosCiencia {
  id             Int      @id @default(autoincrement())
  coletaPrecosId Int
  justificativa  String   // motivo do período em aberto
  usuario        String   // login de quem deu a ciência
  createdAt      DateTime @default(now())

  coletaPrecos ColetaPrecos @relation(fields: [coletaPrecosId], references: [id], onDelete: Cascade)

  @@index([coletaPrecosId])
  @@map("coleta_precos_ciencia")
}

model ColetaPrecosItem {
  id             Int          @id @default(autoincrement())
  coletaPrecosId Int
  idProduto      Int          // id do produto no Nomus
  idSolicitacao  Int?         // id da solicitação de compra no Nomus (quando vinculado)

  coletaPrecos ColetaPrecos @relation(fields: [coletaPrecosId], references: [id], onDelete: Cascade)

  @@index([coletaPrecosId])
  @@index([idProduto])
  @@map("coleta_precos_item")
}

// Registros retornados pelo SQL de coleta no Nomus (uma linha por item: produto + solicitação escolhida)
model ColetaPrecosRegistro {
  id                  Int     @id @default(autoincrement())
  coletaPrecosId      Int
  idProduto           Int     // Id Produto do Nomus
  idSolicitacao       Int?    // Id da solicitação no Nomus (quando vinculado)
  dados               String  // JSON com todas as colunas do SQL (para uso em condições)
  qtdeAprovada        Float?  // Quantidade aprovada pela diretoria (obrigatória para finalizar)
  idFornecedorVencedor Int?   // idPessoa do fornecedor vencedor do item (obrigatório para finalizar, exceto itens cancelados)

  coletaPrecos ColetaPrecos @relation(fields: [coletaPrecosId], references: [id], onDelete: Cascade)

  @@index([coletaPrecosId])
  @@index([idProduto])
  @@map("coleta_precos_registro")
}

// Preços cadastrados por produto/fornecedor na cotação (popup Cadastrar preços)
model ColetaPrecosCotacao {
  id             Int     @id @default(autoincrement())
  coletaPrecosId Int
  idProduto      Int     // Id Produto do Nomus
  idFornecedor   Int     // idPessoa do fornecedor
  precoNF        Float
  percICMS       Float
  percPIS        Float
  percIPI        Float
  percCOFINS     Float
  precoTotal     Float

  coletaPrecos ColetaPrecos @relation(fields: [coletaPrecosId], references: [id], onDelete: Cascade)

  @@unique([coletaPrecosId, idProduto, idFornecedor])
  @@index([coletaPrecosId])
  @@index([idProduto])
  @@map("coleta_precos_cotacao")
}

// Precificação (Engenharia): registro de uma precificação iniciada por produto
model Precificacao {
  id               Int      @id @default(autoincrement())
  idProduto         Int      // id do produto no Nomus
  codigoProduto     String?  // nome no Nomus (código)
  descricaoProduto  String?
  data             DateTime @default(now())
  usuario          String?  // login de quem iniciou
  valoresCampos     String?  // JSON com os campos % (sucata, fosfatizacao, lucro, etc.)

  itens PrecificacaoItem[]

  @@index([idProduto])
  @@index([data])
  @@map("precificacao")
}

// Linhas do resultado do SQL de precificação (lista de materiais / componentes)
model PrecificacaoItem {
  id                Int     @id @default(autoincrement())
  precificacaoId    Int
  idprodutopai      Int?
  codigopai         String?
  descricaopai      String?
  idcomponente      Int?
  codigocomponente  String?
  componente        String?
  qtd               Float   // quantidade (round 5 decimais)
  valorUnitario     Float?  // da segunda consulta Nomus (por idcomponente)
  valorTotal        Float?  // qtd * valorUnitario

  precificacao Precificacao @relation(fields: [precificacaoId], references: [id], onDelete: Cascade)

  @@index([precificacaoId])
  @@map("precificacao_item")
}

/// Registro das programações setoriais a executar.
model ProgramacaoSetorialRegistro {
  id         Int      @id @default(autoincrement())
  nome       String
  status     String   @default("PENDENTE") // PENDENTE | EM_EXECUCAO | CONCLUIDA | CANCELADA
  observacao String?
  criadoPor  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("programacao_setorial_registro")
}

// --- SycroOrder (migrado do sincroorder-crm): pedidos, histórico e notificações ---
model SycroOrderOrder {
  id                    Int      @id @default(autoincrement())
  order_number           String
  delivery_method       String
  current_promised_date  String   // YYYY-MM-DD
  status                 String   @default("PENDING") // PENDING | FINISHED | ESCALATED
  is_urgent              Int      @default(0) // 0 ou 1
  /// TAG de disponibilidade para "Comunicação PD" (DISPONÍVEL / NÃO DISPONÍVEL).
  tag_disponivel         Int      @default(0) // 0 ou 1
  /// Itens (id_pedido do ERP) referenciados por este card. Null = todos os itens do pedido.
  item_ids_json          String?
  /// Códigos (Cod) dos itens referenciados; usado só para exibição/diagnóstico.
  item_codes_json        String?
  created_by             Int?     // Usuario.id (quem criou)
  creator_name           String?  // nome para exibição (migração ou fallback)
  created_at             DateTime @default(now())

  usuarioCriador Usuario?              @relation(fields: [created_by], references: [id], onDelete: SetNull)
  history        SycroOrderHistory[]
  notifications  SycroOrderNotification[]
  reads          SycroOrderOrderRead[]

  @@index([created_by])
  @@index([status])
  @@index([created_at])
  @@map("sycro_order_order")
}

model SycroOrderOrderRead {
  order_id  Int
  user_id   Int
  read_at   DateTime? // quando preenchido = lido; null = não lido (usuário pode marcar como não lida)
  updated_at DateTime @updatedAt

  order SycroOrderOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  usuario Usuario       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([order_id, user_id])
  @@index([user_id])
  @@map("sycro_order_order_read")
}

model SycroOrderHistory {
  id             Int      @id @default(autoincrement())
  order_id       Int
  user_id        Int?     // Usuario.id (quem fez a ação)
  user_name      String?  // para exibição quando user_id null (migração)
  action_type    String   // CREATE | UPDATE
  previous_date  String?
  new_date       String?
  observation    String?
  created_at     DateTime @default(now())

  order SycroOrderOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  usuario Usuario?      @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([order_id])
  @@index([user_id])
  @@map("sycro_order_history")
}

model SycroOrderNotification {
  id         Int      @id @default(autoincrement())
  user_id    Int      // Usuario.id (destinatário)
  message    String
  order_id   Int?
  is_read    Int      @default(0) // 0 ou 1
  created_at DateTime @default(now())

  usuario Usuario?       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  order   SycroOrderOrder? @relation(fields: [order_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([order_id])
  @@map("sycro_order_notification")
}
