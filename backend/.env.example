# Banco local (ajustes, coletas de preços, usuários) - SQLite
# Caminho relativo: usa backend/prisma/dev.db. Se as coletas não aparecerem, use o caminho absoluto do arquivo que tem os dados, ex.:
# DB_URL="file:C:/gestorpedidosSoAco/backend/prisma/dev.db"
DB_URL="file:./prisma/dev.db"

# Conexao Nomus (MySQL) - somente leitura. Senha: # = %23, @ = %40
NOMUS_DB_URL="mysql://usuario:senha@host:3306/weberp_soaco"

# Produção: uma porta para API + SPA (após npm run build:frontend no backend). Ex.: 4000.
# Desenvolvimento na raiz: use "npm run dev" — o script força APP_PORT=4000 (Vite 5180 + 5173+5174+5051 fazem proxy).
APP_PORT=4000
NODE_ENV=production
JWT_SECRET=troque-isto-por-uma-chave-segura

# Domínio: DNS A @ e www → IP público. No MikroTik, NAT WAN TCP 80 e 443 → IP interno do servidor (ex. 10.80.1.187).
# Sem NAT na 80, Let's Encrypt (HTTP-01) falha com "Connection refused" no IP público.

# HTTPS no próprio Node: após deploy\request-acme-cert.ps1 (com NAT 80 OK), PEM em deploy/ssl/ ou:
# SSL_CERT_FILE=C:/caminho/fullchain.pem
# SSL_KEY_FILE=C:/caminho/privkey.pem
# SSL_PORT=443

# Redirecionar HTTP→HTTPS (só após TLS na 443 funcionar):
# FORCE_HTTPS_REDIRECT=true

# Atrás de nginx reverso: TRUST_PROXY=true
# TRUST_PROXY=true
# Cookies só em HTTPS:
# COOKIE_SECURE=true

# Evolution API 2.3.6 (JPG Soluções) - ver backend/docs/EVOLUTION-API-2.3.6.md
EVOLUTION_API_URL=https://api.jpgsolucoesinformatica.com.br
EVOLUTION_API_KEY=sua-apikey
EVOLUTION_API_INSTANCE=
EVOLUTION_WHATSAPP_NUMBER=
